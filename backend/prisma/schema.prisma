// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  fullName       String?
  hashedPassword String
  isActive       Boolean  @default(true)
  isSuperuser    Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("users")
}

model VKGroup {
  id          Int      @id @default(autoincrement())
  vkId        Int      @unique @map("vk_id")
  screenName  String   @unique @map("screen_name")
  name        String
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  posts VKPost[]

  @@map("vk_groups")
}

model VKPost {
  id        Int      @id @default(autoincrement())
  vkId      Int      @unique @map("vk_id")
  groupId   Int      @map("group_id")
  text      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  group    VKGroup     @relation(fields: [groupId], references: [id])
  comments VKComment[]

  @@map("vk_posts")
}

model VKComment {
  id        Int      @id @default(autoincrement())
  vkId      Int      @unique @map("vk_id")
  postId    Int      @map("post_id")
  text      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  post           VKPost                @relation(fields: [postId], references: [id])
  keywordMatches CommentKeywordMatch[]

  @@map("vk_comments")
}

model Keyword {
  id        Int      @id @default(autoincrement())
  word      String   @unique
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  commentMatches CommentKeywordMatch[]

  @@map("keywords")
}

model CommentKeywordMatch {
  id        Int      @id @default(autoincrement())
  commentId Int      @map("comment_id")
  keywordId Int      @map("keyword_id")
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  comment VKComment @relation(fields: [commentId], references: [id])
  keyword Keyword   @relation(fields: [keywordId], references: [id])

  @@unique([commentId, keywordId])
  @@map("comment_keyword_matches")
}
